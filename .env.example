# Copy to .env and fill in. The server loads .env automatically; real environment
# variables take precedence over values here.

# Base URL of your Home Assistant instance.
HA_URL=http://homeassistant.local:8123

# A long-lived access token (Home Assistant → profile → Long-lived access tokens).
HA_TOKEN=

# Optional: bind address and port for the editor's live entity feed/deploy socket.
# The host defaults to loopback so deploy/control is not exposed by accident. If you bind
# outside loopback (for example 0.0.0.0 or a LAN IP), RW_DEPLOY_TOKEN is required.
# RW_HOST=127.0.0.1
# RW_PORT=7420

# Optional: require a deploy/control token. If set here, start the editor with the same value
# exported in the shell or placed in frontend/.env.local as VITE_RW_DEPLOY_TOKEN, so browser
# WebSocket connections include it. Do not commit real secrets.
# RW_DEPLOY_TOKEN=
# VITE_RW_DEPLOY_TOKEN=

# Optional: where collaborative editor document snapshots are stored. Defaults to .rw-data
# (ignored by git). The document survives server restarts; do not put secrets here.
# Default collaboration caps: 2 MB per incoming update, 8 MB compact document state.
# RW_DATA_DIR=.rw-data

# Optional: only needed when intentionally exposing the WebSocket beyond this machine.
# Defaults allow loopback Host/Origin (localhost/127.0.0.1/[::1]) and local standalone files.
# Comma-separated exact values; avoid "*" unless you also require RW_DEPLOY_TOKEN.
# RW_ALLOWED_HOSTS=example.local,192.168.1.20
# RW_ALLOWED_ORIGINS=http://localhost:5173,http://example.local:5173

# Optional: server log verbosity for the structured stdout logger. One of debug|info|warn|error.
# RW_LOG_LEVEL=info

# Safety: nothing actuates until you Deploy a graph from the editor, and even then sinks only
# call services when you've deployed (preview/dry-run otherwise). Just running the server and
# previewing in the editor never changes your home.
