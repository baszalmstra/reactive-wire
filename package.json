{
  "name": "reactive-wire",
  "version": "0.4.0",
  "description": "Node-based reactive automation system for Home Assistant",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run typecheck:core && npm run typecheck:configs && npm run typecheck:scripts && npm run typecheck:e2e",
    "typecheck:core": "tsc --noEmit -p tsconfig.json",
    "typecheck:configs": "tsc --noEmit -p tsconfig.configs.json",
    "typecheck:scripts": "tsc --noEmit -p tsconfig.scripts.json",
    "typecheck:e2e": "tsc --noEmit -p tsconfig.e2e.json",
    "dev": "tsx watch src/server/index.ts",
    "start": "tsx src/server/index.ts",
    "e2e": "playwright test",
    "addon:build": "tsx scripts/build-addon-context.ts",
    "release:prepare": "tsx scripts/prepare-release.ts",
    "e2e:ui": "playwright test --ui",
    "e2e:app": "tsx e2e/start-app.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "home-assistant-js-websocket": "^9.4.0",
    "suncalc": "2.0.1",
    "ws": "^8.18.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@playwright/test": "1.55.1",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
