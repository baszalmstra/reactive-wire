# Reactive Wire server/editor deploy-socket settings (example only; do not commit secrets).

# The server binds the deploy/control WebSocket to loopback by default. Binding outside
# loopback requires RW_DEPLOY_TOKEN.
RW_HOST=127.0.0.1
RW_PORT=7420

# Optional: require a token for WebSocket deploy/control access.
# When set for the server, start the editor with the same value exported in the shell or placed
# in frontend/.env.local as VITE_RW_DEPLOY_TOKEN.
# RW_DEPLOY_TOKEN=
# VITE_RW_DEPLOY_TOKEN=

# Optional: durable collaborative editor document storage. Defaults to .rw-data. Use an
# absolute path on a durable volume for production/container deployments. Default caps:
# 2 MB per incoming collab update, 8 MB compact document state.
# RW_DATA_DIR=.rw-data

# Optional: only when intentionally exposing the WebSocket beyond this machine.
# Defaults allow loopback Host/Origin and local standalone files; comma-separated exact values.
# RW_ALLOWED_HOSTS=example.local,192.168.1.20
# RW_ALLOWED_ORIGINS=http://localhost:5173,http://example.local:5173
